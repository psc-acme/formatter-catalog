{
    "name": "psc-acme/formatter-catalog",
    "description": "Package formatter-catalog for psc-acme organization",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Philipp Scheit",
            "email": "p.scheit@packagist.com"
        }
    ],
    "autoload": {
        "psr-4": {
            "PscAcme\\FormatterCatalog\\": "src/"
        }
    },
    "require": {
        "php": ">=8.2",
        "psr/log": "^3.0",
        "brick/date-time": "^0.7.1",
        "symfony/uid": "^7.0",
        "monolog/monolog": "^3.2.0"
    },
    "require-dev": {
        "vimeo/psalm": "^5.0",
        "mockery/mockery": "^1.6"
    },
    "minimum-stability": "stable",
    "config": {
        "secure-http": false
    },
    "repositories": {
        "private-packagist": {
            "type": "composer",
            "url": "http://repo.packagist.com.lo/psc-acme/"
        },
        "packagist.org": false
    }
}